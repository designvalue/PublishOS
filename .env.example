# Copy to .env.local and fill in values. Never commit .env.local.

# Required (min 16 characters). Example: openssl rand -base64 32
AUTH_SECRET=

# Optional — Neon Postgres (`postgresql://` or `postgres://`). When set, the app uses Neon
# instead of SQLite (recommended on Vercel for durable data). Falls back to SQLite when unset.
# DATABASE_URL=

# Optional — SQLite file path (default: publishos.db in project root).
# On Vercel, if unset, the app defaults to /tmp/publishos.db (ephemeral; use a hosted DB for durable data).
# DATABASE_PATH=publishos.db

# Optional — public origin for Auth.js (must match the URL in the browser; no path, no trailing slash).
# Production example: https://publishos.vercel.app
# AUTH_URL=http://localhost:3000

# Optional — show demo login callout when hostname matches (default: publishosapp.designvalue.co)
# NEXT_PUBLIC_DEMO_LOGIN_HOST=publishosapp.designvalue.co

# Optional Google OAuth
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Optional Resend (transactional email)
# RESEND_API_KEY=
# EMAIL_FROM=
