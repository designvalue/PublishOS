# Copy to .env.local and fill in values. Never commit .env.local.

# Required (min 16 characters). Example: openssl rand -base64 32
AUTH_SECRET=

# Optional — SQLite file path (default: publishos.db in project root)
# DATABASE_PATH=publishos.db

# Optional — public origin for Auth.js in production
# AUTH_URL=http://localhost:3000

# Optional Google OAuth
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Optional Resend (transactional email)
# RESEND_API_KEY=
# EMAIL_FROM=
